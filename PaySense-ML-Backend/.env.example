# ─────────────────────────────────────────────────
# PaySense Guardian — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────

# JWT signing secret — change this to a long random string in production
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=paysense-dev-secret-change-in-prod

# Token expiry in minutes (default: 60)
TOKEN_EXPIRE_MIN=60

# Demo API credentials (what /auth/token accepts)
API_DEMO_USER=paysense
API_DEMO_PASS=guardian2025

# App environment — set to "production" on Render/cloud
APP_ENV=development

# Gemini API key (optional) — enables AI savings tips in /insights/weekly
# Get one free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# CORS allowed origins (comma-separated, use * for dev)
ALLOWED_ORIGINS=*

# Port (injected automatically by Render — don't set this on Render)
# PORT=8000
