        android:pathData="M54,18 L88,34 L88,72 L54,94 L20,72 L20,34 Z"
        android:strokeWidth="3.5"
        android:strokeLineJoin="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:endX="88"
                android:endY="94"
                android:startX="20"
                android:startY="18"
                android:type="linear">
                <item android:color="#FFFFFF" android:offset="0.0" />
                <item android:color="#00D2C4" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Shield Inner Fill (Semi-transparent White) -->
    <path
        android:pathData="M54,22 L83,36 L83,68 L54,87 L25,68 L25,36 Z"
        android:fillColor="#33FFFFFF"/>

    <!-- Lightning Bolt (Neon Yellow/Gold) -->
    <path
        android:pathData="M56,31 L68,52 L54,52 L58,79 L42,56 L54,56 Z"
        android:fillColor="#FFD700"
        android:strokeWidth="1.5"
        android:strokeColor="#FFFFFF" />
</vector>